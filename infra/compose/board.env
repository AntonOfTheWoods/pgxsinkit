# ───────────────────────────────────────────────────────────────────────────────────────────────
#  Board demo stack — environment (DEMO DEFAULTS, NOT SECRETS)
# ───────────────────────────────────────────────────────────────────────────────────────────────
#  Every value below is a PUBLIC Supabase self-hosted default, published in Supabase's own
#  docker/.env.example. The anon/service keys are the demo JWTs signed with the demo JWT secret. They
#  exist only to bring up a throwaway LOCAL cluster with one command, grant nothing of value, and MUST
#  be rotated for any non-local use. The board runs unchanged against real cloud Supabase by pointing
#  these (+ ELECTRIC_SHAPE_URL, the DB URL) at the project instead.
#
#  Consumed by `bun run infra:up` (passed to podman compose via --env-file).
# ───────────────────────────────────────────────────────────────────────────────────────────────

# Postgres superuser password (applies to the `postgres` role — the image's default POSTGRES_USER).
POSTGRES_PASSWORD=your-super-secret-and-long-postgres-password
POSTGRES_DB=postgres

# Shared HS256 secret. The demo anon/service keys below are signed with THIS exact string — it must
# match Supabase's published default verbatim (the `your-` prefix matters), or JWT verification fails.
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
JWT_EXPIRY=3600

# The published Supabase demo anon / service_role JWTs (role-only claims, signed with JWT_SECRET).
# These are the OFFICIAL strings from supabase/docker/.env.example, verbatim — the HS256 signature
# only validates against the exact (pretty-printed) payload encoding Supabase published, so they must
# be copied byte-for-byte, never reconstructed from the decoded claims.
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJhbm9uIiwKICAgICJpc3MiOiAic3VwYWJhc2UtZGVtbyIsCiAgICAiaWF0IjogMTY0MTc2OTIwMCwKICAgICJleHAiOiAxNzk5NTM1NjAwCn0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJzZXJ2aWNlX3JvbGUiLAogICAgImlzcyI6ICJzdXBhYmFzZS1kZW1vIiwKICAgICJpYXQiOiAxNjQxNzY5MjAwLAogICAgImV4cCI6IDE3OTk1MzU2MDAKfQ.DaYlNEoUrrEn2Ig7tqibS-PHK5vgusbcbo7X36XVt4Q

# External origin the browser reaches the gateway on (Kong → 54331). API_EXTERNAL_URL for GoTrue.
BOARD_API_EXTERNAL_URL=http://localhost:54331

# Where the board's Vite client runs (CORS + GoTrue redirect allow-list).
BOARD_SITE_URL=http://localhost:5173
